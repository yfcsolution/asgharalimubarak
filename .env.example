# Local development
WORDPRESS_API_URL=https://public-api.wordpress.com/wp/v2/sites/asgharalimubarakblog.wordpress.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (Vercel) — set these in the Vercel project Environment Variables:
# WORDPRESS_API_URL=https://public-api.wordpress.com/wp/v2/sites/asgharalimubarakblog.wordpress.com
# NEXT_PUBLIC_SITE_URL=https://asgharalimubarak.com

# Content snapshot fallback (filesystem is local-dev only; use KV/Blob/Postgres in production)
CONTENT_SNAPSHOT_STORAGE=filesystem
CONTENT_SNAPSHOT_PATH=.content-cache

# Recommendations (client-side localStorage fallback)
NEXT_PUBLIC_RECOMMENDATIONS_STORAGE_ENABLED=true

# Optional remote ad configuration (JSON with { "campaigns": [...] })
# ADS_CONFIG_URL=

# Optional production snapshot storage adapters (KV / Blob / Postgres) — wire in content-repository.ts
